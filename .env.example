# ==========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# 📋 Hướng dẫn sử dụng:
# 1. Copy file này thành .env
# 2. Điền các giá trị thực tế vào
# 3. KHÔNG commit file .env vào Git
# 
# 🔒 Bảo mật:
# - Development: Dùng config mặc định bên dưới
# - Production: Thay đổi giá trị hoặc set qua Render Dashboard
# - Generate JWT secrets: openssl rand -base64 64

# ==========================================
# 🔧 APPLICATION CONFIGURATION
# ==========================================
PORT=3003
NODE_ENV=development
# Production: NODE_ENV=production

# ==========================================
# 🗄️ DATABASE CONFIGURATION (Supabase)
# ==========================================
# Development
DATABASE_URL=postgresql://username:password@host:5432/database

# Production (thay bằng connection string thực tế)
# DATABASE_URL=postgresql://username:password@production-host:5432/database

# ==========================================
# 🔐 JWT CONFIGURATION
# ==========================================
# Development (dùng key yếu OK)
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=7d

# Production (PHẢI dùng strong keys!)
# Generate: openssl rand -base64 64
# JWT_SECRET=<strong-random-key-here>
# JWT_REFRESH_SECRET=<another-strong-random-key>
# JWT_EXPIRES_IN=1d

# ==========================================
# 🌐 SECURITY CONFIGURATION
# ==========================================
# Development: Allow all
CORS_ORIGIN=*

# Production: Specific domains only
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# 📁 FILE UPLOAD (Cloudinary)
# ==========================================
# Lấy từ: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# 🚦 RATE LIMITING
# ==========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000
# Production: THROTTLE_LIMIT=100

# ==========================================
# 🤖 AI CONFIGURATION
# ==========================================
# Google AI: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GOOGLE_AI_MODEL=gemini-1.5-flash

# Brave Search: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ==========================================
# 🔥 FIREBASE CONFIGURATION (Optional)
# ==========================================
# Nếu muốn lấy API Key từ Firebase Remote Config thay vì .env
# Lấy từ: Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----"


# ==========================================
# 📝 LOGGING
# ==========================================
LOG_LEVEL=debug
# Production: LOG_LEVEL=error