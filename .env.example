# ==========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# 📝 File này là template cho team
# Copy file này thành .env và điền các giá trị thực

# ==========================================
# 🔧 APPLICATION CONFIGURATION
# ==========================================
PORT=3003
NODE_ENV=development

# ==========================================
# 🗄️ DATABASE CONFIGURATION (Supabase)
# ==========================================
# Development: Dùng DATABASE_URL_DEV
# Production: Dùng DATABASE_URL
DATABASE_URL_DEV=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres

# ==========================================
# 🔐 JWT CONFIGURATION
# ==========================================
# Generate bằng: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d

# ==========================================
# 👤 ADMIN ACCOUNT
# ==========================================
# Mật khẩu mặc định cho tài khoản Super Admin (account: admin)
# ⚠️ NÊN ĐỔI sau khi deploy production
ADMIN_DEFAULT_PASSWORD=123456

# ==========================================
# 🌐 SECURITY CONFIGURATION
# ==========================================
CORS_ORIGIN=*

# ==========================================
# 📁 FILE UPLOAD (Cloudinary)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# 🚦 RATE LIMITING
# ==========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000

# ==========================================
# 🤖 AI CONFIGURATION
# ==========================================
GOOGLE_AI_MODEL=gemini-2.5-flash
BRAVE_SEARCH_API_KEY=your_brave_api_key

# ==========================================
# 🔥 FIREBASE CONFIGURATION
# ==========================================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# ==========================================
# 📝 LOGGING
# ==========================================
LOG_LEVEL=debug